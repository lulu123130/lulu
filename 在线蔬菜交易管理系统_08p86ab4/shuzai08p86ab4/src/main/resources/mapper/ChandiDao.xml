<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yb.dao.ChandiDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.yb.entity.ChandiEntity" id="chandiMap">
        <result property="chandi" column="chandi"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.yb.entity.vo.ChandiVO" >
		SELECT * FROM chandi  chandi         
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.yb.entity.vo.ChandiVO" >
		SELECT  chandi.* FROM chandi  chandi 	
 		<where>${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.yb.entity.view.ChandiView" >

		SELECT  chandi.* FROM chandi  chandi 	        
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.yb.entity.view.ChandiView" >
		SELECT * FROM chandi  chandi <where>${ew.sqlSegment}</where>
	</select>
	


</mapper>
