<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yb.dao.ChargerecordDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.yb.entity.ChargerecordEntity" id="chargerecordMap">
        <result property="userid" column="userid"/>
        <result property="username" column="username"/>
        <result property="role" column="role"/>
        <result property="amount" column="amount"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.yb.entity.vo.ChargerecordVO" >
		SELECT * FROM chargerecord  chargerecord         
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.yb.entity.vo.ChargerecordVO" >
		SELECT  chargerecord.* FROM chargerecord  chargerecord 	
 		<where>${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.yb.entity.view.ChargerecordView" >

		SELECT  chargerecord.* FROM chargerecord  chargerecord 	        
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.yb.entity.view.ChargerecordView" >
		SELECT * FROM chargerecord  chargerecord <where>${ew.sqlSegment}</where>
	</select>
	


</mapper>
