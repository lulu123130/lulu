<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yb.dao.ShangjiaDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.yb.entity.ShangjiaEntity" id="shangjiaMap">
        <result property="maijiazhanghao" column="maijiazhanghao"/>
        <result property="mima" column="mima"/>
        <result property="maijiaxingming" column="maijiaxingming"/>
        <result property="yingyezhizhao" column="yingyezhizhao"/>
        <result property="touxiang" column="touxiang"/>
        <result property="xingbie" column="xingbie"/>
        <result property="youxiang" column="youxiang"/>
        <result property="lianxidianhua" column="lianxidianhua"/>
        <result property="sfsh" column="sfsh"/>
        <result property="shhf" column="shhf"/>
        <result property="money" column="money"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.yb.entity.vo.ShangjiaVO" >
		SELECT * FROM shangjia  shangjia         
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.yb.entity.vo.ShangjiaVO" >
		SELECT  shangjia.* FROM shangjia  shangjia 	
 		<where>${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.yb.entity.view.ShangjiaView" >

		SELECT  shangjia.* FROM shangjia  shangjia 	        
        <where>${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.yb.entity.view.ShangjiaView" >
		SELECT * FROM shangjia  shangjia <where>${ew.sqlSegment}</where>
	</select>
	


</mapper>
